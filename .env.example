# Server Configuration
NODE_ENV=development
PORT=5000
MONGO_URL=mongodb+srv://<user>:<password>@<cluster-host>/<dbname>?retryWrites=true&w=majority
CLIENT_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Email (Gmail example — used for local registration verification)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Your Name <your-email@gmail.com>"

# Auth modes (dev defaults: local + demo enabled; prod: Google only)
# Development
AUTH_ALLOW_LOCAL=true
AUTH_ALLOW_DEMO=true
AUTH_ALLOW_GOOGLE=true

# Production example (uncomment and set on your host):
# NODE_ENV=production
# AUTH_ALLOW_LOCAL=false
# AUTH_ALLOW_DEMO=false
# AUTH_ALLOW_GOOGLE=true
# CLIENT_URL=https://your-frontend-domain.com

# Google OAuth (create credentials at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
