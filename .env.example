# =============================================================================
# LOCAL DEVELOPMENT — copy to .env and fill in values
# =============================================================================
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Development database (used when NODE_ENV=development)
# Tip: use a separate Atlas cluster/DB name from production, e.g. katalog-dev
MONGO_URL_DEV=mongodb+srv://<user>:<password>@<cluster-host>/katalog-dev?retryWrites=true&w=majority

# Optional generic fallback (used if MONGO_URL_DEV / MONGO_URL_PROD is not set)
# MONGO_URL=mongodb+srv://<user>:<password>@<cluster-host>/katalog-dev?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-dev-secret-key-here
JWT_EXPIRES_IN=7d

# Email (Gmail example — used for local registration verification)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Your Name <your-email@gmail.com>"

# Auth modes — development defaults
AUTH_ALLOW_LOCAL=true
AUTH_ALLOW_DEMO=true
AUTH_ALLOW_GOOGLE=true

# Google OAuth (create credentials at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# =============================================================================
# PRODUCTION (Railway backend service variables — do not commit real values)
# =============================================================================
# NODE_ENV=production
# CLIENT_URL=https://katalog.up.railway.app
#
# Production database — reference Railway MongoDB plugin or Atlas prod cluster
# MONGO_URL_PROD=mongodb+srv://<user>:<password>@<cluster-host>/katalog-prod?retryWrites=true&w=majority
#
# AUTH_ALLOW_LOCAL=true
# AUTH_ALLOW_DEMO=false
# AUTH_ALLOW_GOOGLE=true
# GOOGLE_CALLBACK_URL=https://<your-backend>.up.railway.app/api/auth/google/callback
# JWT_SECRET=<long-random-production-secret>
